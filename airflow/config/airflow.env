# Configuration Airflow pour la plateforme de centralisation
# À placer dans airflow/config/airflow.cfg ou utiliser comme variables d'environnement

# Core
AIRFLOW__CORE__DAGS_FOLDER=E:/DISQUE C/Desktop/Implementation plateforme/airflow/dags
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__LOAD_DEFAULT_CONNECTIONS=False

# Database (SQLite pour développement)
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:///E:/DISQUE C/Desktop/Implementation plateforme/airflow/airflow.db

# Webserver
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080
AIRFLOW__WEBSERVER__BASE_URL=http://localhost:8080

# Scheduler
AIRFLOW__SCHEDULER__CATCHUP_BY_DEFAULT=False
AIRFLOW__SCHEDULER__MAX_ACTIVE_RUNS_PER_DAG=1

# Logging
AIRFLOW__LOGGING__BASE_LOG_FOLDER=E:/DISQUE C/Desktop/Implementation plateforme/logs/airflow
AIRFLOW__LOGGING__DAG_PROCESSOR_MANAGER_LOG_LOCATION=E:/DISQUE C/Desktop/Implementation plateforme/logs/airflow/dag_processor_manager.log

# MongoDB connection
AIRFLOW_CONN_MONGO_DEFAULT=mongodb://localhost:27018/centralisation_db
